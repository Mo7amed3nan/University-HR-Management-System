@{
    ViewData["Title"] = "Login";

    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0b1220" />
    <title>
        @ViewData["Title"] -
        University HR System
    </title>

    <!-- Bootstrap CSS (Ensure this link is correct or use your local lib) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <!-- Font Awesome for Icons (Optional but recommended) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center; /* Vertical center */
            justify-content: center; /* Horizontal center */
            padding: 24px;
            background:
                radial-gradient(circle at top left, rgba(255, 255, 255, 0.05), transparent 32%),
                radial-gradient(circle at bottom right, rgba(255, 255, 255, 0.03), transparent 26%),
                linear-gradient(180deg, #07080b 0%, #0c0d11 52%, #08090c 100%);
            font-family: 'Manrope', 'Segoe UI', sans-serif;
        }

        .login-card {
            width: 100%;
            max-width: 440px; /* Limit width on large screens */
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 26px; /* Rounded corners */
            background: rgba(21, 22, 27, 0.95);
            box-shadow: 0 22px 44px rgba(0, 0, 0, 0.42);
            overflow: hidden;
        }

        .login-card__header {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.02));
            color: white;
            text-align: center;
            padding: 28px 24px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .login-card__header h3 {
            letter-spacing: -0.03em;
        }

        .login-card__header small {
            color: #a3a3a3;
            letter-spacing: 0.14em;
            text-transform: uppercase;
        }

        .login-card__body {
            padding: 28px 24px 24px;
        }

        .login-card__footer {
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            background: rgba(255, 255, 255, 0.02);
        }

        .input-group-text {
            background: rgba(26, 27, 33, 0.95);
            color: #d1d5db;
            border-color: rgba(255, 255, 255, 0.08);
        }

        .form-control:focus {
            box-shadow: 0 0 0 0.2rem rgba(229, 231, 235, 0.16);
            border-color: #e5e7eb;
        }
    </style>
</head>
<body>

    <div class="card login-card shadow-lg">

        <div class="login-card__header">
            <h3 class="mb-0"><i class="fas fa-university me-2"></i>Login</h3>
            <small>University HR System</small>
        </div>

        <div class="login-card__body">

            @if (ViewBag.Error != null)
            {

                <div class="alert alert-danger text-center" role="alert">
                    <i class="fas fa-exclamation-circle me-1"></i> @ViewBag.Error
            </div>
            }

            <form asp-action="Login" method="post">

                <!-- User ID Input -->
                <div class="mb-3">
                    <label class="form-label fw-bold">User ID / Email</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-user"></i></span>
                        <input type="text" name="userName" class="form-control" placeholder="Enter ID or Admin Email" required autofocus />
                    </div>
                </div>

                <!-- Password Input -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input type="password" name="password" class="form-control" placeholder="Enter Password" required />
                    </div>
                </div>

                <!-- Submit Button -->
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">Sign In</button>
                </div>

            </form>
        </div>

        <div class="login-card__footer text-center text-muted py-3">
            <small>&copy; 2025 University HR System</small>
        </div>
    </div>

</body>
</html>