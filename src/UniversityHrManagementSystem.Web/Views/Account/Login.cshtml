@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#121212" />
    <title>
        @ViewData["Title"] - University HR System
    </title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Segoe+UI:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Custom CSS Modules -->
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />

    <style>
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            background-color: var(--bg-base);
            font-family: var(--font-family);
            color: var(--text-primary);
        }

        .login-wrapper {
            width: 100%;
            max-width: 400px;
        }

        .login-card {
            background-color: var(--bg-surface);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            position: relative;
        }
        
        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background-color: var(--accent-color);
        }

        .login-card__header {
            text-align: center;
            padding: 2rem 2rem 1rem;
        }
        
        .brand-icon {
            color: var(--accent-color);
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .login-card__header h3 {
            font-weight: 600;
            margin-bottom: 0.25rem;
            font-size: 1.5rem;
        }

        .login-card__header p {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin: 0;
        }

        .login-card__body {
            padding: 0 2rem 2rem;
        }

        .btn-login {
            padding: 0.6rem;
            font-weight: 600;
            width: 100%;
        }
    </style>
</head>
<body>

    <div class="login-wrapper">
        <div class="login-card">
            <div class="login-card__header">
                <div class="brand-icon">
                    <i class="fas fa-university"></i>
                </div>
                <h3>Welcome Back</h3>
                <p>Sign in to University HR System</p>
            </div>

            <div class="login-card__body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i> 
                        <div>@ViewBag.Error</div>
                    </div>
                }

                <form asp-action="Login" method="post">
                    <!-- User ID Input -->
                    <div class="mb-3">
                        <label class="form-label">User ID / Email</label>
                        <input type="text" name="userName" class="form-control" placeholder="Enter ID or Admin Email" required autofocus />
                    </div>

                    <!-- Password Input -->
                    <div class="mb-4">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" placeholder="Enter Password" required />
                    </div>

                    <!-- Submit Button -->
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-login">
                            Sign In
                        </button>
                    </div>
                </form>

                <div class="mt-4 p-3 border rounded text-start" style="font-size: 0.85rem; color: var(--text-secondary); background-color: var(--bg-base);">
                    <div class="fw-bold mb-2" style="color: var(--text-primary);"><i class="fas fa-info-circle me-1"></i> Test Accounts</div>
                    <div class="row g-2">
                        <div class="col-6"><strong>Admin:</strong> admin / admin123</div>
                        <div class="col-6"><strong>HR:</strong> hr / hr123</div>
                        <div class="col-6"><strong>Dean:</strong> dean / dean123</div>
                        <div class="col-6"><strong>Emp:</strong> employee / emp123</div>
                    </div>
                </div>
            </div>
            
            <div class="card-footer text-center border-0 bg-transparent py-3 text-muted" style="font-size: 0.8rem; border-top: 1px solid var(--border-color);">
                &copy; @DateTime.Now.Year University HR System
            </div>
        </div>
    </div>

</body>
</html>