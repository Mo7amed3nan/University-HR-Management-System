@{
    ViewData["Title"] = "Generate Payroll";
}

<div class="container mt-5 animate__animated animate__fadeInUp">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-3 border-top border-success border-5">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0 text-success"><i class="fas fa-file-invoice-dollar me-2"></i>Run Payroll</h4>
                </div>

                <div class="card-body p-4">
                    <p class="text-muted small mb-4">Generates the monthly salary calculation including bonuses and deductions.</p>

                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-success">@TempData["Message"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <form action="/HR/GeneratePayroll" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Employee ID</label>
                            <input type="number" name="empId" class="form-control" required />
                        </div>

                        <div class="row mb-4">
                            <div class="col-6">
                                <label class="form-label fw-bold text-secondary">From Date</label>
                                <input type="date" name="from" class="form-control" required />
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold text-secondary">To Date</label>
                                <input type="date" name="to" class="form-control" required />
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">
                                <i class="fas fa-calculator me-2"></i>Calculate Salary
                            </button>
                            <a href="/HR/Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>