@{
    ViewData["Title"] = "HR Dashboard";
    var empId = Context.Session.GetInt32("EmpId");
}

<style>
    .welcome-banner {
        background: linear-gradient(135deg, rgba(210, 153, 34, 0.1), rgba(210, 153, 34, 0.02));
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        padding: 2rem;
        margin-bottom: 2.5rem;
    }
    
    .section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .section-title::after {
        content: "";
        flex: 1;
        height: 1px;
        background-color: var(--border-color);
    }
    
    .action-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1rem;
    }
    
    .action-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        background-color: var(--bg-base);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        color: var(--text-primary);
        text-decoration: none;
        transition: all var(--transition-fast);
    }
    
    .action-item:hover {
        background-color: var(--bg-surface-hover);
        border-color: var(--warning);
        color: var(--text-primary);
        transform: translateY(-2px);
    }
    
    .action-item__icon {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-sm);
        background-color: rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: var(--text-secondary);
        transition: color var(--transition-fast);
    }
    
    .action-item:hover .action-item__icon {
        color: var(--warning);
        background-color: rgba(210, 153, 34, 0.1);
    }

    /* Success styles for specific items */
    .action-item.success:hover { border-color: var(--success); }
    .action-item.success:hover .action-item__icon { color: var(--success); background-color: rgba(46, 160, 67, 0.1); }
    
    /* Danger styles for specific items */
    .action-item.danger:hover { border-color: var(--danger); }
    .action-item.danger:hover .action-item__icon { color: var(--danger); background-color: rgba(248, 81, 73, 0.1); }
    
    .action-item__text {
        font-weight: 500;
        font-size: 0.95rem;
    }
</style>

<div class="container-fluid animate__animated animate__fadeIn">

    <!-- FEEDBACK MESSAGES -->
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- PROFILE HEADER -->
    <div class="welcome-banner">
        <div class="d-flex align-items-center">
            <div class="me-4" style="color: var(--warning);">
                <i class="fas fa-user-tie fa-3x"></i>
            </div>
            <div>
                <h2 class="mb-2" style="font-weight: 700;">HR Management Center</h2>
                <div style="color: var(--text-secondary); font-size: 0.95rem;">
                    <span><i class="fas fa-id-card me-1"></i> HR ID: <strong class="text-white">#@empId</strong></span>
                    <span class="mx-3 text-muted">|</span>
                    <span><i class="fas fa-user-tag me-1"></i> Role: <strong class="text-white">Human Resources</strong></span>
                </div>
            </div>
        </div>
    </div>

    <!-- LEAVE APPROVALS -->
    <h3 class="section-title"><i class="fas fa-clipboard-check text-warning"></i> Leave Approvals</h3>
    <div class="action-grid mb-5">
        <a href="/HR/ProcessAnnualAccidentalLeaves" class="action-item success">
            <div class="action-item__icon"><i class="fas fa-calendar-check"></i></div>
            <span class="action-item__text">Annual & Accidental</span>
        </a>
        <a href="/HR/ProcessUnpaidLeaves" class="action-item warning">
            <div class="action-item__icon"><i class="fas fa-wallet"></i></div>
            <span class="action-item__text">Unpaid Leaves</span>
        </a>
        <a href="/HR/ProcessCompensationLeaves" class="action-item info">
            <div class="action-item__icon"><i class="fas fa-gift"></i></div>
            <span class="action-item__text">Compensation Leaves</span>
        </a>
    </div>

    <!-- PAYROLL & DEDUCTIONS -->
    <h3 class="section-title"><i class="fas fa-money-bill-wave text-success"></i> Payroll & Deductions</h3>
    <div class="action-grid mb-4">
        <a href="/HR/ApplyDeduction" class="action-item danger">
            <div class="action-item__icon"><i class="fas fa-minus-circle"></i></div>
            <span class="action-item__text">Apply Deduction</span>
        </a>
        <a href="/HR/GeneratePayroll" class="action-item success">
            <div class="action-item__icon"><i class="fas fa-file-invoice-dollar"></i></div>
            <span class="action-item__text">Generate Monthly Payroll</span>
        </a>
    </div>

</div>