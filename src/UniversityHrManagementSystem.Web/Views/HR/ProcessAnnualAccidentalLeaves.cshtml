@model List<Uni_HR_Management_System.Models.ConsolidatedLeaveViewModel>
@{
    ViewData["Title"] = "Process Annual Leaves";
}

<div class="container py-4 animate__animated animate__fadeIn">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="fas fa-calendar-check me-2"></i>Pending Annual/Accidental</h2>
        <a href="/HR/Index" class="btn btn-secondary shadow-sm">Back</a>
    </div>

    <div class="card shadow border-0 border-top border-primary border-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light text-primary">
                        <tr>
                            <th>Req ID</th>
                            <th>Type</th>
                            <th>Duration</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@item.RequestId</td>
                                <td>
                                    @if (item.Type.Contains("Annual"))
                                    {
                                        <span class="badge bg-primary">Annual</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-warning text-dark">Accidental</span>
                                    }
                                </td>
                                <td>
                                    @item.StartDate?.ToString("MM/dd") <i class="fas fa-arrow-right mx-1 text-muted"></i> @item.EndDate?.ToString("MM/dd")
                                </td>
                                <td>
                                    <form action="/HR/ProcessAnnualAccidentalLeaves" method="post">
                                        <input type="hidden" name="requestId" value="@item.RequestId" />
                                        <button type="submit" class="btn btn-success btn-sm w-100 shadow-sm">
                                            <i class="fas fa-check me-1"></i> Process
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-4">No pending leaves found.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>