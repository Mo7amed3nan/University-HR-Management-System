<!DOCTYPE html>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - University HR</title>
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Keep original d-flex layout but add smooth collapsing */
        .app-shell {
            display: flex;
            align-items: stretch;
            min-height: 100vh;
        }

        /* SIDEBAR */
        .sidebar {
            flex: 0 0 250px;
            width: 250px;
            min-height: 100vh;
            background: linear-gradient(180deg, #343a40 0%, #212529 100%);
            color: #fff;
            transition: all 0.25s ease;
            overflow: hidden;
        }

            /* Collapsed state: hide content but keep animation */
            .sidebar.collapsed {
                flex: 0 0 0;
                width: 0;
                min-width: 0;
                padding: 0;
                opacity: 0;
                pointer-events: none;
            }

            .sidebar .nav-link {
                color: rgba(255,255,255,.8);
                padding: 15px 20px;
                border-left: 4px solid transparent;
                transition: 0.3s;
                white-space: nowrap;
            }

                .sidebar .nav-link:hover, .sidebar .nav-link.active {
                    color: #fff;
                    background-color: rgba(255,255,255,0.1);
                    border-left-color: #0d6efd;
                }

                .sidebar .nav-link i {
                    width: 25px;
                    text-align: center;
                    margin-right: 10px;
                }

        .sidebar-header {
            padding: 20px;
            background-color: rgba(0,0,0,0.2);
            text-align: center;
        }

        .content-wrapper {
            flex: 1 1 auto;
            padding: 20px;
            transition: margin-left .25s ease;
            width: 100%;
        }

        .sidebar.collapsed + .content-wrapper {

        }

        .collapse-menu .nav-link {
            padding-left: 50px;
            font-size: 0.9em;
        }


        #sidebarToggle {
            min-width: 42px;
        }
    </style>
</head>
<body>
    @{
        var userRole = HttpContextAccessor.HttpContext.Session.GetString("Role");
    }

    <div class="app-shell">

        <nav id="leftSidebar" class="sidebar">
            <div class="sidebar-header">
                <h4><i class="fas fa-university me-2"></i>Uni HR</h4>
                <small class="text-light">@userRole Panel</small>
            </div>

            <ul class="nav flex-column mt-3">
                <li class="nav-item">
                    @if (userRole == "Admin")
                    {
                        <a class="nav-link" href="/Admin/Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                    }
                    else if (userRole == "HR")
                    {
                        <a class="nav-link" href="/HR/Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                    }
                    else
                    {
                        <a class="nav-link" href="/Employee/Index"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                    }
                </li>

                @* ADMIN MENU *@
                @if (userRole == "Admin")
                {
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="collapse" href="#menuReports" role="button">
                            <i class="fas fa-chart-bar"></i> Reports <i class="fas fa-caret-down float-end"></i>
                        </a>
                        <div class="collapse collapse-menu" id="menuReports">
                            <a class="nav-link" href="/Admin/ListEmployees">All Employees</a>
                            <a class="nav-link" href="/Admin/DepartmentStats">Dept Stats</a>
                            <a class="nav-link" href="/Admin/RejectedLeaves">Rejected Leaves</a>
                            <a class="nav-link" href="/Admin/ViewAttendanceYesterday">Yesterday Att.</a>
                            <a class="nav-link" href="/Admin/ViewPerformance">Winter Perf.</a>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="collapse" href="#menuActions" role="button">
                            <i class="fas fa-cogs"></i> System Actions <i class="fas fa-caret-down float-end"></i>
                        </a>
                        <div class="collapse collapse-menu" id="menuActions">
                            <a class="nav-link" href="/Admin/AddHoliday">Add Holiday</a>
                            <a class="nav-link" href="/Admin/UpdateAttendance">Update Attendance</a>
                            <a class="nav-link" href="/Admin/ReplaceEmployee">Replace Emp</a>
                            <a class="nav-link" href="/Admin/UpdateStatus">Update Status</a>
                            <a class="nav-link" href="/Admin/RemoveDayOff">Clean DayOffs</a>
                            <a class="nav-link" href="/Admin/RemoveApprovedLeaves">Clean Leaves</a>
                        </div>
                    </li>
                }

                @* HR MENU *@
                @if (userRole == "HR")
                {
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="collapse" href="#menuHRLeaves" role="button">
                            <i class="fas fa-check-circle"></i> Leave Approvals <i class="fas fa-caret-down float-end"></i>
                        </a>
                        <div class="collapse collapse-menu" id="menuHRLeaves">
                            <a class="nav-link" href="/HR/ProcessAnnualAccidentalLeaves">Annual/Accidental</a>
                            <a class="nav-link" href="/HR/ProcessUnpaidLeaves">Unpaid</a>
                            <a class="nav-link" href="/HR/ProcessCompensationLeaves">Compensation</a>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="collapse" href="#menuPayroll" role="button">
                            <i class="fas fa-money-check-alt"></i> Payroll & Ded. <i class="fas fa-caret-down float-end"></i>
                        </a>
                        <div class="collapse collapse-menu" id="menuPayroll">
                            <a class="nav-link" href="/HR/ApplyDeduction">Apply Deduction</a>
                            <a class="nav-link" href="/HR/GeneratePayroll">Run Payroll</a>
                        </div>
                    </li>
                }

                @* ACADEMIC EMPLOYEE MENU *@
                @if (userRole == "Academic")
                {
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="collapse" href="#menuInfo" role="button">
                            <i class="fas fa-user-circle"></i> My Info <i class="fas fa-caret-down float-end"></i>
                        </a>
                        <div class="collapse collapse-menu" id="menuInfo">
                            <a class="nav-link" href="/Employee/ViewPerformance">Performance</a>
                            <a class="nav-link" href="/Employee/ViewAttendance">Attendance</a>
                            <a class="nav-link" href="/Employee/ViewPayroll">Payroll</a>
                            <a class="nav-link" href="/Employee/ViewDeductions">Deductions</a>
                            <a class="nav-link" href="/Employee/ViewLeaveStatus">Leave Status</a>
                        </div>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="collapse" href="#menuLeave" role="button">
                            <i class="fas fa-calendar-plus"></i> Apply Leave <i class="fas fa-caret-down float-end"></i>
                        </a>
                        <div class="collapse collapse-menu" id="menuLeave">
                            <a class="nav-link" href="/Employee/SubmitAnnualLeave">Annual</a>
                            <a class="nav-link" href="/Employee/SubmitAccidentalLeave">Accidental</a>
                            <a class="nav-link" href="/Employee/SubmitMedicalLeave">Medical</a>
                            <a class="nav-link" href="/Employee/SubmitUnpaidLeave">Unpaid</a>
                            <a class="nav-link" href="/Employee/SubmitCompensationLeave">Compensation</a>
                        </div>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="collapse" href="#menuDean" role="button">
                            <i class="fas fa-user-tie"></i> Dean Actions <i class="fas fa-caret-down float-end"></i>
                        </a>
                        <div class="collapse collapse-menu" id="menuDean">
                            <a class="nav-link" href="/Employee/ViewPendingUnpaidLeave">Approve Unpaid</a>
                            <a class="nav-link" href="/Employee/ViewPendingAnnualLeave">Approve Annual</a>
                            <a class="nav-link" href="/Employee/EvaluateEmployee">Evaluate Employee</a>
                        </div>
                    </li>
                }

                <li class="nav-item mt-5">
                    <a class="nav-link text-danger" href="/Account/Logout">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </li>
            </ul>
        </nav>

        <!-- MAIN CONTENT -->
        <div class="content-wrapper">
            <div class="d-flex align-items-center mb-3">
                <button id="sidebarToggle" class="btn btn-outline-secondary me-2" type="button" aria-pressed="false" aria-controls="leftSidebar" title="Toggle menu">
                    <i class="fas fa-bars"></i>
                </button>

                <h1 class="h5 mb-0">@ViewData["Title"]</h1>
            </div>

            <main role="main" class="animate__animated animate__fadeIn">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            const sidebar = document.getElementById('leftSidebar');
            const toggleBtn = document.getElementById('sidebarToggle');

            if (!sidebar || !toggleBtn) return;

            toggleBtn.addEventListener('click', function () {
                const isCollapsed = sidebar.classList.toggle('collapsed');

                toggleBtn.setAttribute('aria-pressed', isCollapsed ? 'true' : 'false');
            });
        })();
    </script>
</body>
</html>
