@model IEnumerable<Uni_HR_Management_System.Models.Deduction>

@{
    ViewData["Title"] = "My Deductions";
}

<div class="container py-4 animate__animated animate__fadeIn">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger fw-bold"><i class="fas fa-minus-circle me-2"></i>My Deductions</h2>
        <a href="/Employee/Index" class="btn btn-secondary shadow-sm">Back</a>
    </div>

    <!-- Filter Card -->
    <div class="card shadow-sm mb-4 border-start border-danger border-4">
        <div class="card-body">
            <form action="/Employee/ViewDeductions" method="post" class="row g-3 align-items-center">
                <div class="col-auto">
                    <label class="col-form-label fw-bold"><i class="fas fa-filter me-1"></i> Select Month:</label>
                </div>
                <div class="col-auto">
                    <input type="number" name="month" class="form-control" placeholder="1-12" min="1" max="12" required />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-danger"><i class="fas fa-search me-2"></i>View Deductions</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Table -->
    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-bordered mb-0 align-middle">
                    <thead class="bg-danger text-white">
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Amount</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Date?.ToString("yyyy-MM-dd")</td>
                                <td class="text-capitalize">@item.Type?.Replace("_", " ")</td>
                                <td class="fw-bold text-danger">@item.Amount?.ToString("C")</td>
                                <td class="text-center">
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill">Finalized</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">No deductions found for the selected month.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>  