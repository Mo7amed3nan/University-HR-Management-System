@{
    ViewData["Title"] = "Apply Unpaid Leave";
}

<div class="container mt-5 animate__animated animate__fadeInUp">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-secondary text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-wallet me-2"></i>Apply for Unpaid Leave</h4>
                </div>
                <div class="card-body p-4">

                    <form action="/Employee/SubmitUnpaidLeave" method="post">

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Start Date</label>
                                <input type="date" name="start" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">End Date</label>
                                <input type="date" name="end" class="form-control" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Memo Description</label>
                            <textarea name="description" class="form-control" rows="3" required placeholder="Explain why you need unpaid leave..."></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Document File Name</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-file-upload"></i></span>
                                <input type="text" name="filename" class="form-control" placeholder="e.g. Memo.pdf" required />
                            </div>
                            <div class="form-text">Enter the name of the uploaded file on server.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-secondary btn-lg shadow-sm">
                                <i class="fas fa-paper-plane me-2"></i>Submit Request
                            </button>
                            <a href="/Employee/Index" class="btn btn-outline-dark">Cancel</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>