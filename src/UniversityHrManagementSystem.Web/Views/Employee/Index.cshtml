@{
    ViewData["Title"] = "Employee Dashboard";
    var empId = Context.Session.GetInt32("EmpId");
    var userRole = Context.Session.GetString("Role");
}

<style>
    .welcome-banner {
        background: linear-gradient(135deg, rgba(88, 166, 255, 0.1), rgba(88, 166, 255, 0.02));
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        padding: 2rem;
        margin-bottom: 2.5rem;
    }
    
    .section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .section-title::after {
        content: "";
        flex: 1;
        height: 1px;
        background-color: var(--border-color);
    }
    
    .action-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1rem;
    }
    
    .action-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        background-color: var(--bg-base);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        color: var(--text-primary);
        text-decoration: none;
        transition: all var(--transition-fast);
    }
    
    .action-item:hover {
        background-color: var(--bg-surface-hover);
        border-color: var(--info);
        color: var(--text-primary);
        transform: translateY(-2px);
    }
    
    .action-item__icon {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-sm);
        background-color: rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: var(--text-secondary);
        transition: color var(--transition-fast);
    }
    
    .action-item:hover .action-item__icon {
        color: var(--info);
        background-color: rgba(88, 166, 255, 0.1);
    }
    
    .action-item__text {
        font-weight: 500;
        font-size: 0.95rem;
    }

    /* Danger styles for specific items */
    .action-item.danger:hover { border-color: var(--danger); }
    .action-item.danger:hover .action-item__icon { color: var(--danger); background-color: rgba(248, 81, 73, 0.1); }
    
    /* Warning styles for specific items */
    .action-item.warning:hover { border-color: var(--warning); }
    .action-item.warning:hover .action-item__icon { color: var(--warning); background-color: rgba(210, 153, 34, 0.1); }
    
    /* Success styles for specific items */
    .action-item.success:hover { border-color: var(--success); }
    .action-item.success:hover .action-item__icon { color: var(--success); background-color: rgba(46, 160, 67, 0.1); }
</style>

<div class="container-fluid animate__animated animate__fadeIn">
    
    <!-- FEEDBACK MESSAGES -->
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- PROFILE HEADER -->
    <div class="welcome-banner" style="background: linear-gradient(135deg, rgba(88, 166, 255, 0.1), rgba(88, 166, 255, 0.02));">
        <div class="d-flex align-items-center">
            <div class="me-4" style="color: var(--info);">
                <i class="fas fa-user-graduate fa-3x"></i>
            </div>
            <div>
                <h2 class="mb-2" style="font-weight: 700;">Academic Dashboard</h2>
                <div style="color: var(--text-secondary); font-size: 0.95rem;">
                    <span><i class="fas fa-id-card me-1"></i> Employee ID: <strong class="text-white">#@empId</strong></span>
                    <span class="mx-3 text-muted">|</span>
                    <span><i class="fas fa-user-tag me-1"></i> Role: <strong class="text-white">@userRole</strong></span>
                </div>
            </div>
        </div>
    </div>

    <!-- LEAVE MANAGEMENT -->
    <h3 class="section-title"><i class="fas fa-paper-plane text-info"></i> Apply for Leave</h3>
    <div class="action-grid mb-5">
        <a href="/Employee/SubmitAnnualLeave" class="action-item info">
            <div class="action-item__icon"><i class="fas fa-calendar-check"></i></div>
            <span class="action-item__text">Annual Leave</span>
        </a>
        <a href="/Employee/SubmitAccidentalLeave" class="action-item warning">
            <div class="action-item__icon"><i class="fas fa-car-crash"></i></div>
            <span class="action-item__text">Accidental Leave</span>
        </a>
        <a href="/Employee/SubmitMedicalLeave" class="action-item danger">
            <div class="action-item__icon"><i class="fas fa-procedures"></i></div>
            <span class="action-item__text">Medical Leave</span>
        </a>
        <a href="/Employee/SubmitCompensationLeave" class="action-item success">
            <div class="action-item__icon"><i class="fas fa-gift"></i></div>
            <span class="action-item__text">Compensation Leave</span>
        </a>
        <a href="/Employee/SubmitUnpaidLeave" class="action-item">
            <div class="action-item__icon"><i class="fas fa-wallet"></i></div>
            <span class="action-item__text">Unpaid Leave</span>
        </a>
        <a href="/Employee/ViewLeaveStatus" class="action-item">
            <div class="action-item__icon"><i class="fas fa-list-alt"></i></div>
            <span class="action-item__text">View My Leave Status</span>
        </a>
    </div>

    <!-- DEAN ACTIONS (CONDITIONAL) -->
    @if (Context.Session.GetString("IsDean") == "True")
    {
        <h3 class="section-title mt-5"><i class="fas fa-user-tie text-warning"></i> Upper Board Actions (Dean)</h3>
        <div class="action-grid mb-4">
            <a href="/Employee/ViewPendingAnnualLeave" class="action-item success">
                <div class="action-item__icon"><i class="fas fa-check-double"></i></div>
                <span class="action-item__text">Approve Annual Leaves</span>
            </a>
            <a href="/Employee/ViewPendingUnpaidLeave" class="action-item warning">
                <div class="action-item__icon"><i class="fas fa-file-signature"></i></div>
                <span class="action-item__text">Approve Unpaid Leaves</span>
            </a>
            <a href="/Employee/EvaluateEmployee" class="action-item info">
                <div class="action-item__icon"><i class="fas fa-gavel"></i></div>
                <span class="action-item__text">Evaluate Employee</span>
            </a>
        </div>
    }

</div>
