@model IEnumerable<Uni_HR_Management_System.Models.Attendance>

@{
    ViewData["Title"] = "My Attendance";
}

<div class="container py-4 animate__animated animate__fadeIn">
    
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary fw-bold"><i class="fas fa-clock me-2"></i>My Attendance</h2>
            <p class="text-muted mb-0">Attendance records for the current month.</p>
        </div>
        <a href="/Employee/Index" class="btn btn-secondary shadow-sm">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>

    <!-- Table Card -->
    <div class="card shadow border-0 border-top border-primary border-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-bordered mb-0 align-middle text-center">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="py-3">Date</th>
                            <th class="py-3">Check In</th>
                            <th class="py-3">Check Out</th>
                            <th class="py-3">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.Date?.ToString("yyyy-MM-dd")</td>
                                <td class="text-success">@(item.CheckInTime?.ToString() ?? "--:--")</td>
                                <td class="text-danger">@(item.CheckOutTime?.ToString() ?? "--:--")</td>
                                <td>
                                    @if (item.Status == "Attended")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3">Attended</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-3 text-dark">@item.Status</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-muted py-4">No attendance records found for this month.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>