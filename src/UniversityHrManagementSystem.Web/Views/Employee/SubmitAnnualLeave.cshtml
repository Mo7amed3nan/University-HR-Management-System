@{
    ViewData["Title"] = "Apply Annual Leave";
}

<div class="container mt-5 animate__animated animate__fadeInUp">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-calendar-check me-2"></i>Apply for Annual Leave</h4>
                </div>
                <div class="card-body p-4">
                    <form action="/Employee/SubmitAnnualLeave" method="post">

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Start Date</label>
                                <input type="date" name="start" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">End Date</label>
                                <input type="date" name="end" class="form-control" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Replacement Employee ID</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-user-friends"></i></span>
                                <input type="number" name="replacementId" class="form-control" placeholder="Enter ID" required />
                            </div>
                            <div class="form-text">Enter the ID of the colleague covering for you.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="fas fa-paper-plane me-2"></i>Submit Request
                            </button>
                            <a href="/Employee/Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>