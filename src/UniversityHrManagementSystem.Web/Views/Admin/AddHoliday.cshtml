@{
    ViewData["Title"] = "Add Holiday";
}

<div class="container mt-5 animate__animated animate__fadeInUp">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-calendar-plus me-2"></i>Add Official Holiday</h4>
                </div>

                <div class="card-body p-4">
                    <form action="/Admin/AddHoliday" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Holiday Name</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-tag"></i></span>
                                <input type="text" name="name" class="form-control" placeholder="e.g. New Year" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Start Date</label>
                                <input type="date" name="start" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">End Date</label>
                                <input type="date" name="end" class="form-control" required />
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">
                                <i class="fas fa-save me-2"></i>Save Holiday
                            </button>
                            <a href="/Admin/Index" class="btn btn-light border">Cancel</a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>