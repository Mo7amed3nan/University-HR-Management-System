@model List<Uni_HR_Management_System.Models.AllPerformance>

<div class="container mt-5">
    <h2 class="mb-4 text-primary">Employee Performance (Winter Semesters)</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            No performance records found for Winter semesters.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Performance ID</th>
                    <th>Employee ID</th>
                    <th>Semester</th>
                    <th>Rating (1-5)</th>
                    <th>Comments</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.PerformanceId</td>
                        <td>@item.EmpId</td>
                        <td>
                            <span class="badge bg-info text-dark">@item.Semester</span>
                        </td>
                        <td>
                            @if (item.Rating >= 4)
                            {
                                <span class="badge bg-success">@item.Rating</span>
                            }
                            else if (item.Rating >= 2)
                            {
                                <span class="badge bg-warning text-dark">@item.Rating</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">@item.Rating</span>
                            }
                        </td>
                        <td>@item.Comments</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <a href="/Admin/Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>