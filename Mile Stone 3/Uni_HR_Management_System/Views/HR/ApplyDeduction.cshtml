@{
    ViewData["Title"] = "Apply Deduction";
}

<div class="container mt-5 animate__animated animate__fadeInUp">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-3 border-top border-danger border-5">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0 text-danger"><i class="fas fa-user-minus me-2"></i>Apply Deduction</h4>
                </div>

                <div class="card-body p-4">

                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-success">@TempData["Message"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <form action="/HR/ApplyDeduction" method="post">

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">Target Employee ID</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-id-card"></i></span>
                                <input type="number" name="empId" class="form-control" required placeholder="Enter ID" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">Deduction Type</label>
                            <select name="type" class="form-select" required>
                                <option value="" disabled selected>Select Deduction Type...</option>
                                <option value="MissingHours">Missing Hours (&lt; 8 hours)</option>
                                <option value="MissingDays">Missing Days (Absent)</option>
                                <option value="Unpaid">Unpaid Leave</option>
                            </select>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg shadow-sm">
                                <i class="fas fa-gavel me-2"></i>Apply Penalty
                            </button>
                            <a href="/HR/Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>