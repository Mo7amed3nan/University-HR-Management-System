@{
    ViewData["Title"] = "HR Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h1 class="text-primary">HR Dashboard</h1>
        <a href="/Account/Logout" class="btn btn-danger">Logout</a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success:</strong> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error:</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Leave Management</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a href="/HR/ProcessAnnualAccidentalLeaves" class="list-group-item list-group-item-action">
                        Process Annual & Accidental Leaves
                    </a>
                    <a href="/HR/ProcessUnpaidLeaves" class="list-group-item list-group-item-action">
                        Process Unpaid Leaves
                    </a>
                    <a href="/HR/ProcessCompensationLeaves" class="list-group-item list-group-item-action">
                        Process Compensation Leaves
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Financials & Payroll</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a href="/HR/ApplyDeduction" class="list-group-item list-group-item-action">
                        Apply Deduction (Hours/Days)
                    </a>
                    <a href="/HR/GeneratePayroll" class="list-group-item list-group-item-action">
                        Generate Monthly Payroll
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>