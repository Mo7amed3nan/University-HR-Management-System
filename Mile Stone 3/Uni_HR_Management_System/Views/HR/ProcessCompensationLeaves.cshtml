@model List<Uni_HR_Management_System.Models.ConsolidatedLeaveViewModel>
@{
    ViewData["Title"] = "Process Compensation Leaves";
}

<div class="container py-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-success fw-bold"><i class="fas fa-gift me-2"></i>Pending Compensation</h2>
        <a href="/HR/Index" class="btn btn-secondary shadow-sm">Back</a>
    </div>

    <div class="card shadow border-0 border-top border-success border-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-success text-white">
                        <tr>
                            <th>Req ID</th>
                            <th>Compensation Date</th>
                            <th>Original Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@item.RequestId</td>
                                <td>@item.StartDate?.ToShortDateString()</td>
                                <td class="text-muted">@item.EndDate?.ToShortDateString()</td> <!-- Assuming EndDate holds OriginalDate logic or similar -->
                                <td>
                                    <form action="/HR/ProcessCompensationLeaves" method="post">
                                        <input type="hidden" name="requestId" value="@item.RequestId" />
                                        <button type="submit" class="btn btn-primary btn-sm w-100 shadow-sm">
                                            <i class="fas fa-check me-1"></i> Process
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-4">No pending requests found.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>