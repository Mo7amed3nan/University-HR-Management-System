@model List<Uni_HR_Management_System.Models.ConsolidatedLeaveViewModel>

<div class="container mt-4">
    <h2 class="mb-4 text-info">Pending Compensation Leaves</h2>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No pending compensation leaves found.</div>
    }
    else
    {
        <table class="table table-bordered">
            <thead class="table-info">
                <tr>
                    <th>Req ID</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.RequestId</td>
                        <td>@item.StartDate?.ToShortDateString()</td>
                        <td>@item.EndDate?.ToShortDateString()</td>
                        <td>
                            <form asp-action="ProcessCompensationLeaves" method="post">
                                <input type="hidden" name="requestId" value="@item.RequestId" />
                                <button type="submit" class="btn btn-primary btn-sm">Process Approval</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    <a href="/HR/Index" class="btn btn-secondary mt-3">Back to Dashboard</a>
</div>