@model IEnumerable<Uni_HR_Management_System.Models.Performance>

<h2>My Performance</h2>
<a href="/Employee/Index">Back</a>

<!-- Filter Form -->
<form action="/Employee/ViewPerformance" method="post">
    <label>Enter Semester (e.g., W23):</label>
    <input type="text" name="semester" required maxlength="3" />
    <button type="submit">Search</button>
</form>
<br />

<table border="1">
    <thead><tr><th>ID</th><th>Rating</th><th>Comments</th><th>Semester</th></tr></thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.PerformanceId</td>
                <td>@item.Rating</td>
                <td>@item.Comments</td>
                <td>@item.Semester</td>
            </tr>
        }
    </tbody>
</table>