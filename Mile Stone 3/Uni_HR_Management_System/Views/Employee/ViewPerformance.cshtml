@model IEnumerable<Uni_HR_Management_System.Models.Performance>
@{
    ViewData["Title"] = "My Performance";
}

<div class="container py-4 animate__animated animate__fadeIn">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="fas fa-chart-line me-2"></i>Performance History</h2>
        <a href="/Employee/Index" class="btn btn-secondary shadow-sm">Back</a>
    </div>

    <!-- Search Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form action="/Employee/ViewPerformance" method="post" class="row g-3 align-items-center">
                <div class="col-auto">
                    <label class="col-form-label fw-bold">Search Semester:</label>
                </div>
                <div class="col-auto">
                    <input type="text" name="semester" class="form-control" placeholder="e.g. W23" required maxlength="3" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-search me-2"></i>Search</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Table -->
    <div class="card shadow border-0 border-top border-primary border-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-bordered mb-0 align-middle">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th>Semester</th>
                            <th class="text-center">Rating (1-5)</th>
                            <th>Comments</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.Semester</td>
                                <td class="text-center">
                                    @for (int i = 0; i < item.Rating; i++)
                                    {
                                        <i class="fas fa-star text-warning"></i>
                                    }
                                    @for (int i = 0; i < (5 - item.Rating); i++)
                                    {
                                        <i class="far fa-star text-muted"></i>
                                    }
                                </td>
                                <td class="text-muted">@item.Comments</td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">No records found. Search for a semester.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>