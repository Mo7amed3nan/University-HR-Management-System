@{
    ViewData["Title"] = "Apply Accidental Leave";
}

<div class="container mt-5 animate__animated animate__fadeInUp">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-3 border-top border-warning border-5">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0 text-warning"><i class="fas fa-car-crash me-2"></i>Apply for Accidental Leave</h4>
                </div>
                <div class="card-body p-4">

                    <div class="alert alert-warning d-flex align-items-center" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        <div>Accidental leaves are for emergencies only.</div>
                    </div>

                    <form action="/Employee/SubmitAccidentalLeave" method="post">

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Start Date</label>
                                <input type="date" name="start" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">End Date</label>
                                <input type="date" name="end" class="form-control" required />
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning text-dark fw-bold btn-lg shadow-sm">
                                <i class="fas fa-paper-plane me-2"></i>Submit Request
                            </button>
                            <a href="/Employee/Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>