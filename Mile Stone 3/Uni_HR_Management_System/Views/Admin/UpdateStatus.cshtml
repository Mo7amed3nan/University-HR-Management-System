@{
    ViewData["Title"] = "Update Status";
}

<div class="container mt-5 text-center animate__animated animate__fadeInUp">
    <div class="card shadow mx-auto" style="max-width: 450px;">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="fas fa-sync-alt me-2"></i>Update Status</h4>
        </div>
        <div class="card-body p-5">
            <p class="text-muted mb-4">Manually refresh an employee's status (Active/OnLeave) based on their current leave records.</p>

            <form action="/Admin/UpdateStatus" method="post">
                <div class="input-group mb-4">
                    <span class="input-group-text"><i class="fas fa-hashtag"></i></span>
                    <input type="number" name="empId" class="form-control form-control-lg" placeholder="Employee ID" required />
                </div>

                <button type="submit" class="btn btn-info text-white w-100 btn-lg shadow-sm">Update Status Now</button>
            </form>
        </div>
        <div class="card-footer bg-white border-0 pb-4">
            <a href="/Admin/Index" class="btn btn-outline-secondary btn-sm">Cancel</a>
        </div>
    </div>
</div>