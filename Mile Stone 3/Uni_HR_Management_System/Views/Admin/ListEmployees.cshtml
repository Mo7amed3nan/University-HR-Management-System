@model List<Uni_HR_Management_System.Models.AllEmployeeProfile>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>All Employee Profiles</h2>
        <a href="/Admin/Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-warning">No employees found in the database.</div>
    }
    else
    {
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Contract</th>
                    <th>Day Off</th>
                    <th>Annual Bal.</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr>
                        <td>@emp.EmployeeId</td>
                        <td>@emp.FirstName @emp.LastName</td>
                        <td>@emp.Email</td>

                        <td>
                            @if (emp.EmploymentStatus?.ToLower() == "active")
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else if (emp.EmploymentStatus?.ToLower() == "resigned")
                            {
                                <span class="badge bg-danger">Resigned</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@emp.EmploymentStatus</span>
                            }
                        </td>

                        <td>@emp.TypeOfContract</td>
                        <td>@emp.OfficialDayOff</td>
                        <td>@emp.AnnualBalance</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>