@model IEnumerable<Uni_HR_Management_System.Models.NoEmployeeDept>
@{
    ViewData["Title"] = "Department Statistics";
}

<div class="container animate__animated animate__fadeIn">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-info"><i class="fas fa-chart-bar me-2"></i>Department Statistics</h2>
        <a href="/Admin/Index" class="btn btn-secondary shadow-sm">Back</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm border-top border-info border-4 h-100">
                    <div class="card-body text-center p-4">
                        <div class="mb-3 text-info">
                            <i class="fas fa-building fa-3x"></i>
                        </div>
                        <h4 class="card-title fw-bold">@item.Department</h4>
                        <div class="display-4 fw-bold text-dark my-2">@item.NumberOfEmployees</div>
                        <p class="text-muted mb-0">Total Employees</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>