@model IEnumerable<Uni_HR_Management_System.Models.AllRejectedMedical>
@{
    ViewData["Title"] = "Rejected Leaves";
}

<div class="container animate__animated animate__fadeIn">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger"><i class="fas fa-ban me-2"></i>Rejected Medical Leaves</h2>
        <a href="/Admin/Index" class="btn btn-secondary shadow-sm">Back</a>
    </div>

    <div class="card shadow-sm border-danger border-top border-3">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="bg-danger text-white">
                    <tr>
                        <th>Req ID</th>
                        <th>Employee ID</th>
                        <th>Type</th>
                        <th>Reason / Disability</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.RequestId</td>
                            <td>@item.EmpId</td>
                            <td>@item.Type</td>
                            <td>@item.DisabilityDetails</td>
                            <td><span class="badge bg-danger">REJECTED</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>